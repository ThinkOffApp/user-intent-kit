{
  "name": "user-intent-kit",
  "version": "0.2.1",
  "description": "Cross-device user intent state for AI agents. Profile + live signals + derived state.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "intent": "./bin/intent.js",
    "uik-daemon": "./bin/uik-daemon.js"
